{
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Error",
            "SlimData": "Warning",
            "SlimFaas": "Warning",
            "DotNext": "Warning",
            "DotNext.Net.Cluster": "Warning",
            "DotNext.Net.Cluster.Consensus.Raft": "Warning"
        }
    },
    "UseKubeConfig": false,
    "AllowedHosts": "*",
    "Kestrel": {
        "Limits": {
            "KeepAliveTimeout": "00:05:00",
            "RequestHeadersTimeout": "00:05:00",
            "MaxRequestBodySize": 524288000,
            "MinRequestBodyDataRate": {
                "BytesPerSecond": 240,
                "GracePeriod": "00:00:10"
            }
        }
    },
    "OpenTelemetry": {
        "Enable": false,
        "Endpoint": "",
        "ServiceName": "",
        "EnableConsoleExporter": false,
        "ExcludedUrls": ["/health", "/metrics", "/ready", "/SlimData", "/status-functions", "/cluster-consensus", "/wake-function"]
    },
    "Data": {
        "DefaultVisibility": "Private"
    },
    "SlimFaas": {
        "AllowUnsecureSsl": false,
        "EnableFront": true,
        "JobsConfiguration": null,
        "CorsAllowOrigin": "*",
        "BaseSlimDataUrl": "http://{pod_name}.{service_name}.{namespace}.svc:3262",
        "BaseFunctionUrl": "http://{pod_ip}:{pod_port}",
        "BaseFunctionPodUrl": "http://{pod_ip}:{pod_port}",
        "Namespace": "default",
        "Orchestrator": "Kubernetes",
        "PodScaledUpByDefaultWhenInfrastructureHasNeverCalled": false,
        "MetricsScraping": {
            "ScrapeIntervalMilliseconds": 5000,
            "MaxResponseBytes": 8388608,
            "MaxLineBytes": 65536,
            "MaxSelectedSeriesPerTarget": 10000,
            "RequestTimeoutSeconds": 10
        },
        "RateLimiting": {
            "Enabled": false,
            "CpuHighThreshold": 80.0,
            "CpuLowThreshold": 60.0,
            "SampleIntervalMs": 1000,
            "RetryAfterSeconds": 5,
            "ExcludedPaths": ["/health", "/metrics", "/ready"]
        }
    },
    "SlimData": {
        "Directory": null,
        "Configuration": null,
        "AllowColdStart": false,
        "WarmupRounds": 10000,
        "BackupDirectory": null,
        "WalMemoryManagement": "SharedMemory",
        "SnapshotIntervalEntries": 500,
        "SnapshotIntervalBytes": 33554432,
        "Files": {
            "MaxInFlightBytes": 268435456,
            "UnknownLengthReservationBytes": 268435456,
            "MaxPendingTransfers": 128,
            "QueueWaitTimeoutSeconds": 30,
            "DropPageCache": true
        },
        "Membership": {
            "ChangeTimeoutSeconds": 60,
            "AnnouncementTimeoutSeconds": 70,
            "RemovalMissingCycles": 3
        }
    },
    "RaftClientHandler": {
        "ConnectTimeoutMilliseconds": 2000,
        "PooledConnectionLifetimeMinutes": 5,
        "PooledConnectionIdleTimeoutSeconds": 30,
        "MaxConnectionsPerServer": 100
    },
    "Workers": {
        "QueuesDelayMilliseconds": 10,
        "JobsDelayMilliseconds": 1000,
        "ReplicasSynchronizationDelayMilliseconds": 3000,
        "HistorySynchronizationDelayMilliseconds": 500,
        "ScaleReplicasDelayMilliseconds": 1000,
        "HealthDelayMilliseconds": 1000,
        "HealthDelayToExitSeconds": 60,
        "HealthDelayToStartHealthCheckSeconds": 20
    }
}
